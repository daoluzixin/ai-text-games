# AI文游游戏厅 配置文件
# 复制此文件为 .env 并填入你的配置

# ======== AI API 配置 ========
# 推荐使用豆包（火山引擎），免费额度高、国内速度快
# 获取方式: https://console.volcengine.com/ark → 创建 API Key
API_KEY=your_api_key_here

# API 地址（默认为豆包，也可以换成其他 OpenAI 兼容的服务）
# 豆包:     https://ark.cn-beijing.volces.com/api/v3
# DeepSeek: https://api.deepseek.com/v1
# Kimi:     https://api.moonshot.cn/v1
# OpenAI:   https://api.openai.com/v1
API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型名称
# 豆包:     doubao-1-5-pro-256k-250115（推荐，上下文长，适合文游）
# DeepSeek: deepseek-chat
# Kimi:     moonshot-v1-128k
# OpenAI:   gpt-4o
MODEL_NAME=doubao-1-5-pro-256k-250115

# ======== 生成参数 ========
# AI 单次回复的最大 token 数（太小会导致输出截断，建议 4096~8192）
MAX_TOKENS=8192

# 生成温度（0~1，越高越有创意，越低越稳定）
# TEMPERATURE=0.9

# ======== 长上下文记忆 ========
# 触发滚动摘要的阈值：历史消息条数超过此值时，把早期消息压缩成「前情提要」
# 注意是「条数」（user/assistant 各算一条），约等于 SUMMARY_TRIGGER/2 轮对话
SUMMARY_TRIGGER=20

# 摘要后保留的最近消息条数（保证最近剧情有完整原文，不丢细节）
KEEP_RECENT_MESSAGES=12

# 核心铁律提取：从 docx 开头截取的最大字符数（作为末尾重述的「核心设定」）
CORE_RULES_MAX_CHARS=600

# ======== 服务配置 ========
# 端口
PORT=8080

# 游戏文件目录（存放 .docx 指令文件的目录）
GAMES_DIR=./games

# 头像目录
AVATARS_DIR=./avatars

# 会话数据库文件路径（SQLite）
DB_PATH=./sessions.db
